DATABASE_URL="postgresql://postgres:password@localhost:5432/aiza"
REDIS_URL="redis://localhost:6379"
JWT_SECRET="your_jwt_secret_here"

# ─── Cloudflare R2 Configuration ─────────────────────────────────────────
# Sign up for free: https://dash.cloudflare.com/?to=/:account/r2
# 10GB free per month + $0.015/GB ($0.015 egress)
# Documentation: https://developers.cloudflare.com/r2/get-started/
# Create API Token: https://dash.cloudflare.com/profile/api-tokens

S3_ENDPOINT="https://<your-account-id>.r2.cloudflarestorage.com"
S3_REGION="auto"
S3_BUCKET="your-bucket-name"
S3_ACCESS_KEY_ID="your-r2-access-key-id"
S3_SECRET_ACCESS_KEY="your-r2-secret-access-key"

# Optional: Set custom domain for better CDN performance
S3_PUBLIC_URL="https://cdn.example.com"

# ─── Stripe Configuration ────────────────────────────────────────────────
STRIPE_SECRET_KEY="your_stripe_secret_key"

PORT=3000
